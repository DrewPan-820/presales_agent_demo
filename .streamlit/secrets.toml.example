# Streamlit Community Cloud 的 Secrets 模板
#
# 用法：
# 1) 本地调试：把本文件复制为 .streamlit/secrets.toml（已在 .gitignore 中），
#    或继续使用项目根目录的 .env。两者任选其一即可，.env 优先级更高。
# 2) 云端部署：登录 https://share.streamlit.io → 进入 App → Settings → Secrets，
#    把下面的键值粘贴进去并填入真实值，保存后应用会自动重启。

LLM_API_KEY = "sk-xxxxxxxxxxxxxxxxxxxxxxxx"
LLM_BASE_URL = "https://dashscope-intl.aliyuncs.com/compatible-mode/v1"
LLM_MODEL = "qwen3-max"
